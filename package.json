{
  "name": "yls-desktop-widget",
  "productName": "伊莉思用量查询",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron:watch\" \"npm:dev:electron:start\"",
    "dev:renderer": "vite",
    "dev:electron:watch": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron:start": "wait-on tcp:5173 dist-electron/electron/main.js dist-electron/electron/preload.cjs && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build --base ./",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dist:win": "npm run build && electron-builder --win --x64 --publish never",
    "dist:win:dir": "npm run build && electron-builder --dir --win --x64 --publish never",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json && tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run"
  },
  "build": {
    "appId": "com.shilianmalaxiangguo.ylsdesktopwidget",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@nuxt/ui": "^4.6.1",
    "vue": "^3.5.32",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.7.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.0.12",
    "jsdom": "^27.0.1",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vitest": "^4.0.2",
    "vue-tsc": "^3.1.1",
    "wait-on": "^9.0.1"
  }
}
