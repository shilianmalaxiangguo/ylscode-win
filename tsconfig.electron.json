{
  "extends": "./tsconfig.node.json",
  "compilerOptions": {
    "outDir": "dist-electron",
    "rootDir": ".",
    "types": ["node", "electron"]
  },
  "include": [
    "electron/main.ts",
    "electron/preload.cts",
    "electron/ipc.ts",
    "electron/store.ts",
    "electron/quota-service.ts",
    "shared/mappers.ts",
    "shared/types.ts"
  ],
  "exclude": ["electron/__tests__/**", "shared/__tests__/**"]
}
